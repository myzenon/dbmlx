{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pnpm: build",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "build"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "pnpm: watch:extension",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "watch:extension"],
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "pnpm: watch:webview",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "watch:webview"],
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
