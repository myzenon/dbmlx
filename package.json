{
  "name": "dbmlx",
  "displayName": "DBMLX: Database Visual and Design",
  "description": "Interactive .dbmlx diagram renderer for VSCode. Git-friendly layout persistence, DDD-aware TableGroup contexts, LSP intelligence, SVG/PNG export, and viewport culling for 5000+ tables.",
  "version": "0.1.5",
  "publisher": "si-zenon",
  "icon": "docs/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "dbml",
    "dbmlx",
    "diagram",
    "erd",
    "database",
    "schema",
    "ddd"
  ],
  "main": "./dist/extension/extension/extension.js",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/myzenon/dbmlx"
  },
  "homepage": "https://github.com/myzenon/dbmlx#readme",
  "bugs": {
    "url": "https://github.com/myzenon/dbmlx/issues"
  },
  "contributes": {
    "commands": [
      {
        "command": "dbmlx.openDiagram",
        "title": "Open Diagram",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.resetLayout",
        "title": "Auto Re-arrange Diagram",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.pruneOrphans",
        "title": "Prune Orphan Layout Entries",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.zoomIn",
        "title": "Zoom In",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.zoomOut",
        "title": "Zoom Out",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.resetView",
        "title": "Reset View",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.fitToContent",
        "title": "Fit to Content",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.exportSvg",
        "title": "Export Diagram as SVG",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.exportToSql",
        "title": "Export Schema to SQL",
        "category": "DBMLX"
      },
      {
        "command": "dbmlx.importFromSql",
        "title": "Import Schema from SQL",
        "category": "DBMLX"
      }
    ],
    "keybindings": [
      {
        "command": "dbmlx.zoomIn",
        "key": "ctrl+=",
        "mac": "cmd+=",
        "when": "activeWebviewPanelId == 'dbmlx.diagram'"
      },
      {
        "command": "dbmlx.zoomIn",
        "key": "ctrl+shift+=",
        "mac": "cmd+shift+=",
        "when": "activeWebviewPanelId == 'dbmlx.diagram'"
      },
      {
        "command": "dbmlx.zoomOut",
        "key": "ctrl+-",
        "mac": "cmd+-",
        "when": "activeWebviewPanelId == 'dbmlx.diagram'"
      },
      {
        "command": "dbmlx.resetView",
        "key": "ctrl+0",
        "mac": "cmd+0",
        "when": "activeWebviewPanelId == 'dbmlx.diagram'"
      },
      {
        "command": "dbmlx.fitToContent",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'dbmlx.diagram'"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .dbmlx",
          "command": "dbmlx.openDiagram",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceExtname == .dbmlx",
          "command": "dbmlx.openDiagram",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "dbmlx",
        "extensions": [
          ".dbmlx"
        ],
        "aliases": [
          "Database Markup Language Extension",
          "dbmlx"
        ]
      }
    ],
    "grammars": [
      {
        "language": "dbmlx",
        "scopeName": "source.dbmlx",
        "path": "./syntaxes/dbmlx.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:dbmlx",
    "onCommand:dbmlx.openDiagram"
  ],
  "scripts": {
    "build:extension": "node -e \"require('fs').rmSync('dist/extension',{recursive:true,force:true})\" && esbuild src/extension/extension.ts --bundle --outfile=dist/extension/extension/extension.js --external:vscode --platform=node --format=cjs --minify --sourcemap",
    "build:webview": "vite build",
    "build": "pnpm run build:extension && pnpm run build:webview",
    "watch:extension": "esbuild src/extension/extension.ts --bundle --outfile=dist/extension/extension/extension.js --external:vscode --platform=node --format=cjs --sourcemap --watch",
    "watch:webview": "vite build --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "version:sync": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs && git add README.md llms.txt",
    "vscode:prepublish": "pnpm run build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@dbml/core": "^3.9.0",
    "preact": "^10.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
