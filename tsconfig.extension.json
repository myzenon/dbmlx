{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist/extension",
    "rootDir": "src",
    "jsx": "preserve",
    "lib": ["ES2022"],
    "types": ["node", "vscode"]
  },
  "include": ["src/extension/**/*", "src/shared/**/*"]
}
